# Supabase (auto-injected by Vercel integration)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# GitHub
GITHUB_TOKEN=your-github-token

# Backend (Railway service URL - set after OpenClaw deploy)
BACKEND_URL=https://YOUR_SERVICE.up.railway.app
NEXT_PUBLIC_API_URL=https://YOUR_SERVICE.up.railway.app

# OpenClaw Gateway (from Railway template)
OPENCLAW_URL=https://openclaw-xxx.up.railway.app
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# AI Models
OPENAI_API_KEY=your-openai-key
